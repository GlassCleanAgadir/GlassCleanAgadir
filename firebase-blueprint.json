{
  "entities": {
    "EstimateRequest": {
      "title": "Estimate Request",
      "description": "A request for a window cleaning estimate from a customer.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer's full name" },
        "email": { "type": "string", "format": "email", "description": "Customer's email address" },
        "phone": { "type": "string", "description": "Customer's phone number" },
        "address": { "type": "string", "description": "Service address" },
        "serviceType": { "type": "string", "enum": ["Residential", "Commercial", "Post Construction"], "description": "Type of service requested" },
        "message": { "type": "string", "description": "Additional details or questions" },
        "status": { "type": "string", "enum": ["Pending", "Contacted", "Completed"], "description": "Status of the request" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the request was created" }
      },
      "required": ["name", "email", "phone", "serviceType", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review for the service.",
      "type": "object",
      "properties": {
        "authorName": { "type": "string", "description": "Name of the reviewer" },
        "rating": { "type": "number", "description": "Rating out of 5" },
        "comment": { "type": "string", "description": "Review text" },
        "date": { "type": "string", "format": "date-time", "description": "Timestamp of the review" }
      },
      "required": ["authorName", "rating", "comment", "date"]
    },
    "User": {
      "title": "User",
      "description": "A registered user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["admin", "client"], "description": "User's role in the system" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the user account was created" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/estimates/{estimateId}": {
      "schema": "EstimateRequest",
      "description": "Collection of estimate requests."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of customer reviews."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
